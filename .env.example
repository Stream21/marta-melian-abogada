###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-in-production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Docker: usuario y contraseña deben coincidir con POSTGRES_USER / POSTGRES_PASSWORD
DATABASE_URL="postgresql://bufete:CHANGE_ME@postgres:5432/bufete?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> PostgreSQL (Docker) ###
POSTGRES_DB=bufete
POSTGRES_USER=bufete
POSTGRES_PASSWORD=CHANGE_ME
###< PostgreSQL (Docker) ###

###> Holded (Facturación) – entorno desarrollador ###
# Producción: cuenta real en https://app.holded.com → Configuración → Integraciones → API
# Desarrollo (mock local, sin cuenta Holded):
#   HOLDED_API_KEY=dev-mock-key-123
#   HOLDED_BASE_URL=http://nginx/api/mock/holded
#   HOLDED_API_URL=http://nginx/api/mock/holded
# Desde el host (sin Docker): sustituir nginx por localhost:8080
HOLDED_API_KEY=dev-mock-key-123
HOLDED_BASE_URL=http://nginx/api/mock/holded
HOLDED_API_URL=http://nginx/api/mock/holded
HOLDED_MOCK_KEY=dev-mock-key-123
###< Holded (Facturación) ###

###> Stripe (Pagos) – entorno desarrollador ###
# Dashboard: https://dashboard.stripe.com → Developers → API keys
# Usar claves de TEST (pk_test_... y sk_test_...) para desarrollo
# Webhook: Developers → Webhooks → Add endpoint → URL: https://tu-ngrok-o-dominio/api/webhooks/stripe → evento checkout.session.completed → copiar "Signing secret" (whsec_...)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PUBLISHABLE_KEY=pk_test_
###< Stripe (Pagos y Domiciliaciones) ###

###> Twilio (WhatsApp + SMS) – entorno desarrollador ###
# Cuenta: https://www.twilio.com/console
# Account SID y Auth Token en la consola
# SMS (TWILIO_SMS_FROM): SOLO OTP de firma de documentos
# WhatsApp (TWILIO_WHATSAPP_FROM): notificaciones al cliente (enlace portal, avisos)
# WhatsApp sandbox: Messaging → Try it out → Send a WhatsApp message
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=
###< Twilio (WhatsApp + SMS) ###

###> Mercure (tiempo real) ###
MERCURE_URL=http://mercure
MERCURE_PUBLIC_URL=http://localhost:3000
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!
# Añadir URL ngrok del frontend cuando use túneles: https://xxxx.ngrok-free.app
MERCURE_CORS_ORIGINS="http://localhost:5173 http://localhost:8080 http://127.0.0.1:5173"
###< Mercure ###

###> ngrok (desarrollo — perfil docker-compose ngrok) ###
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Tras levantar ngrok, copiar URLs del inspector http://localhost:4040
NGROK_API_URL=
NGROK_FRONT_URL=
NGROK_MERCURE_URL=
###< ngrok ###

###> Frontend (redirects Stripe) ###
FRONTEND_BASE_URL=http://localhost:5173
FRONTEND_SUCCESS_URL=http://localhost:5173/payment/success
FRONTEND_CANCEL_URL=http://localhost:5173/payment/cancel
###< Frontend ###

###> Correo (Symfony Mailer) ###
# Desarrollo con Mailpit (bandeja web en http://localhost:8025):
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM=notificaciones@bufete.local
MAILER_FROM_NAME="Marta Melián Abogados"
# Producción (ejemplo Gmail / SendGrid):
# MAILER_DSN=smtp://usuario:contraseña@smtp.example.com:587
###< Correo ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8080
###< symfony/routing ###
