# Evitar que el contexto de build incluya carpetas que provocan errores en Windows (tar/win32)
.git
.gitignore
.idea
.vscode
*.md
.env
.env.*
!.env.example

# Frontend: no necesario para build PHP; se monta en runtime. Evita node_modules/win32 en contexto
/frontend

# Dependencias: se instalan dentro del contenedor
/vendor
/node_modules

# Cache y generados
/var
.phpunit.cache
*.log

# Docker
Dockerfile*
docker-compose*
.dockerignore
